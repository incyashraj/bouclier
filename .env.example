# ============================================================
#  Bouclier — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── RPC Endpoints ────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ETH_MAINNET_RPC_URL=https://eth.llamarpc.com

# ── API Keys ─────────────────────────────────────────────────
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
ALCHEMY_API_KEY=

# ── Deployer Wallet (TEST ONLY — never use a funded mainnet key here) ──
DEPLOYER_PRIVATE_KEY=

# ── IPFS / Pinata ────────────────────────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=

# ── The Graph ────────────────────────────────────────────────
GRAPH_STUDIO_DEPLOY_KEY=
SUBGRAPH_NAME_SEPOLIA=bouclier-base-sepolia
SUBGRAPH_NAME_MAINNET=bouclier-base-mainnet

# ── Backend ──────────────────────────────────────────────────
DATABASE_URL=postgresql://bouclier:password@localhost:5432/bouclier
REDIS_URL=redis://localhost:6379

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Certora ──────────────────────────────────────────────────
CERTORAKEY=
