{
  "compilerOptions": {
    "target":          "ES2020",
    "lib":             ["ES2020"],
    "module":          "NodeNext",
    "moduleResolution":"NodeNext",
    "strict":          true,
    "noEmit":          true,
    "skipLibCheck":    true,
    "outDir":          "./dist",
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
