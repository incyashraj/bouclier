{
  "name": "@bouclier/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Bouclier Agent Trust Layer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bouclier-protocol/bouclier"
  },
  "keywords": [
    "ai-agents",
    "web3",
    "permissions",
    "bouclier",
    "viem"
  ],
  "files": [
    "dist",
    "src"
  ],
  "module": "src/index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "bun run src/index.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "dependencies": {
    "viem": "^2.47.4"
  }
}
